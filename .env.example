# =============================================================================
# ReviewFlow — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
DEBUG=true

# -----------------------------------------------------------------------------
# Auth (JWT)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-random-secret
# JWT_ALGORITHM=HS256              # default: HS256
# JWT_EXPIRE_MINUTES=60            # default: 60

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o              # default: gpt-4o

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=reviewflow
POSTGRES_PASSWORD=reviewflow
POSTGRES_DB=reviewflow
# POSTGRES_PORT=5432               # default: 5432
# POSTGRES_VERSION=16-alpine       # default: 16-alpine

# DATABASE_URL for local dev (without Docker).
# IMPORTANT: Keep this in sync with POSTGRES_USER/PASSWORD/DB above.
# Docker Compose overrides this with container networking automatically.
DATABASE_URL=postgresql+asyncpg://reviewflow:reviewflow@localhost:5432/reviewflow

# -----------------------------------------------------------------------------
# Qdrant (Vector DB)
# -----------------------------------------------------------------------------
# QDRANT_HOST=localhost            # default: localhost (docker overrides to "qdrant")
# QDRANT_PORT=6333                 # default: 6333
# QDRANT_GRPC_PORT=6334            # default: 6334
# QDRANT_COLLECTION=coding_standards  # default: coding_standards
# QDRANT_VERSION=latest            # default: latest

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-token-here

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
# MCP_PORT=8001                    # default: 8001
# MCP_SERVER_URL is auto-configured by docker-compose (http://mcp:<MCP_PORT>)
# Override only for non-Docker local dev:
# MCP_SERVER_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
# API_PORT=8000                    # default: 8000

# =============================================================================
# Docker Compose automatically overrides for container networking:
#   DATABASE_URL   → postgres:<POSTGRES_PORT>
#   MCP_SERVER_URL → mcp:<MCP_PORT>
#   QDRANT_HOST    → qdrant
# =============================================================================
